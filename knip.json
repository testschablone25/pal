{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "next.config.ts!",
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/app/**/route.ts",
    "src/app/**/loading.tsx",
    "src/app/**/error.tsx",
    "src/app/**/not-found.tsx",
    "src/middleware.ts",
    "src/proxy.ts",
    "scripts/*.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/components/ui/**",
    "src/test/**"
  ],
  "ignoreDependencies": [
    "typescript-language-server"
  ],
  "rules": {
    "enumMembers": "warn",
    "exports": "error",
    "types": "warn",
    "nsTypes": "warn",
    "nsExports": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error"
  }
}
